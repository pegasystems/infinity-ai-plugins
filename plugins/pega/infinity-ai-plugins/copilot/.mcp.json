{
  "mcpServers": {
    "pega-infinity-authoring": {
      "tools": [
        "*"
      ],
      "command": "java",
      "args": [
        "-jar",
        "${PLUGIN_ROOT}/resources/infinity-rules-mcp.jar",
        "--spring.profiles.active=stdio"
      ],
      "env": {
        "PEGA_SKILLS_PATH": "${PLUGIN_ROOT}/resources/pega-skills",
        "PEGA_CLIENT_MODE": "copilot-plugin",
        "PEGA_LOCAL_SKILLS_PATH": "${PEGA_LOCAL_SKILLS_PATH}"
      }
    }
  }
}
